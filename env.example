NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only service role key (never expose in browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of your app (used for Paystack callbacks, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: digits-only SA mobile for hero “WhatsApp Us” (e.g. 27821234567). If unset, wa.me opens with prefilled message only.
# NEXT_PUBLIC_WHATSAPP_NUMBER=27821234567

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
# Optionally override currency (default is ZAR). For NG accounts use NGN.
PAYSTACK_CURRENCY=ZAR

# Resend email service
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL="Bookings <no-reply@example.com>"

# Admin email address to receive booking notifications
BOOKING_ADMIN_EMAIL=admin@example.com

# Optional overrides for reply-to and BCC on booking emails
# Defaults (if unset) are:
#   reply-to: bookings@shalean.com
#   BCC:      accounts@shalean.com
BOOKING_REPLY_TO_EMAIL=bookings@example.com
BOOKING_BCC_EMAIL=accounts@example.com

