# Supabase (required for booking persistence and auth)
# Get these from your project: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server Actions (optional; prevents "UnrecognizedActionError" when action IDs change)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or on macOS/Linux: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Paystack (required for online payments and cleaner payouts)
# Get keys from https://dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=
# Base URL for Paystack callback (e.g. https://yoursite.com or http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In Paystack Dashboard → Settings → Webhooks, set URL to: ${NEXT_PUBLIC_APP_URL}/api/paystack/webhook
# (receives charge.success for bookings and transfer.success/failed/reversed for cleaner payouts)
